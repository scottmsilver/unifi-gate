# Cloudflare Worker configuration for UniFi Gate Auth
# Copy this to wrangler.toml and fill in your values.
# Deployment: npx wrangler deploy
# Dev: npx wrangler dev

name = "unifi-gate-auth"
main = "src/index.js"
compatibility_date = "2024-01-01"

# KV Namespace for approved users
# Create with: npx wrangler kv:namespace create "APPROVED_USERS"
# Then update the id below with the returned namespace ID
[[kv_namespaces]]
binding = "APPROVED_USERS"
id = "YOUR_KV_NAMESPACE_ID"

# Environment variables (set via wrangler secret or dashboard)
# FIREBASE_PROJECT_ID - Your Firebase project ID
# ORIGIN_URL - Your Cloudflare Tunnel origin URL (e.g., https://uuid.cfargotunnel.com)

[vars]
# Public configuration (non-sensitive)
# FIREBASE_PROJECT_ID = "your-project-id"

# Route configuration - update with your domain
[[routes]]
pattern = "gate.yourdomain.com/*"
zone_name = "yourdomain.com"

[[routes]]
pattern = "gate-dev.yourdomain.com/*"
zone_name = "yourdomain.com"
